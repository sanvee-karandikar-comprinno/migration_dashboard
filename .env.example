# ============================================================================
# DATABASE MIGRATION DASHBOARD - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and update values according to YOUR system.
# Do NOT commit .env to version control (it contains passwords).
# ============================================================================

# --- MSSQL (Microsoft SQL Server) ---
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USERNAME=sa
MSSQL_PASSWORD=YourPasswordHere
MSSQL_DRIVER=ODBC Driver 17 for SQL Server
# Set to true for Windows Integrated Authentication (ignores username/password)
MSSQL_TRUSTED_CONNECTION=false

# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=YourPasswordHere

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=YourPasswordHere

# --- MongoDB ---
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USERNAME=
MONGODB_PASSWORD=
# Optional: full connection string (overrides host/port/user/pass if set)
MONGODB_URI=

# --- Connection Pooling Settings ---
# These control how many database connections are kept open and reused.
# pool_size: Number of permanent connections kept in the pool.
# max_overflow: Extra connections allowed above pool_size during peak load.
# pool_timeout: Seconds to wait for a connection from pool before giving up.
# pool_recycle: Seconds after which a connection is recycled (prevents stale connections).
# pool_pre_ping: If true, tests connections before using them (avoids broken pipe errors).
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# MongoDB pool settings
MONGODB_MAX_POOL_SIZE=20
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# --- Migration Settings ---
# Default batch size for data migration (rows per batch insert)
DEFAULT_BATCH_SIZE=1000
